// FlowDesk Prisma schema — V1 (v1.2.3 / ARCHITECTURE v1.4)
//
// Models below are grouped by purpose:
//   1. Live polled data        — FlowAlert, GexSnapshot, DarkPoolPrint,
//                                MarketTideBar, NetImpactDaily
//   2. Reference / config      — TickerMetadata, WatchesCriteria
//   3. Computed daily artifacts — HitListDaily, AiSummary
//   4. Auth (Auth.js v5 + Whop) — User, Account, Session, VerificationToken
//   5. 🗄 Archived in v1.2.3    — SentimentSnapshot (commented at file end);
//                                see ARCHITECTURE §3 for XPost,
//                                AnalystProfile, DivergenceAlert which were
//                                never added.
//
// References: docs/FlowDesk_PRD.md · docs/ARCHITECTURE.md §3.

// Two generator blocks — one per consumer. `prisma generate` runs both
// sequentially so each environment gets the typed client where it expects
// to find it.
//
// `worker` writes into worker/node_modules so the Railway worker image
// (which preserves the dev tree layout — /app/worker/ + /app/prisma/
// side-by-side, see worker/Dockerfile) finds the typed client at runtime.
//
// `nextjs` writes into the repo root's node_modules where the Next.js
// app's `@prisma/client` is installed. This is what Vercel's build step
// (`prisma generate && next build`, see package.json) populates.

generator worker {
  provider = "prisma-client-js"
  output   = "../worker/node_modules/.prisma/client"
}

generator nextjs {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════
// 1. Live polled data
// ═══════════════════════════════════════════════════════════════

// Raw flow alerts polled from UW /api/option-trades/flow-alerts.
// Polling cadence: 30s mkt / 5m off (ARCHITECTURE §2.1).
// Retention: 60 days (enforced by flow-retention-sweep cron at 03:00 ET).
model FlowAlert {
  id         String   @id // UW's alert id
  capturedAt DateTime @map("captured_at") // when we polled it
  time       DateTime // alert timestamp per UW
  ticker     String   @db.VarChar(10)
  type       String   @db.VarChar(4) // CALL | PUT
  side       String   @db.VarChar(4) // BUY | SELL
  sentiment  String   @db.VarChar(8) // BULLISH | BEARISH
  exec       String   @db.VarChar(8) // SWEEP | FLOOR | SINGLE | BLOCK
  multiLeg   Boolean  @map("multi_leg")
  contract   String // "$145P May 15"
  strike     Decimal  @db.Decimal(12, 4)
  expiry     DateTime @db.Date
  size       Int
  oi         Int
  premium    Decimal  @db.Decimal(16, 2)
  spot       Decimal  @db.Decimal(12, 4)
  rule       String
  confidence String   @db.VarChar(4) // HIGH | MED | LOW (v1.2.1 enum)
  sector     String   @db.VarChar(32) // matches `Sector` union (PRD §18)

  // Added v1.3 for Lottos / Opening Sweepers preset views (PRD §6 tabs).
  // Nullable so the migration is non-destructive — older rows backfill as NULL,
  // and any preset view's WHERE clause naturally excludes NULL rows.
  askPrem      Decimal? @map("ask_prem")       @db.Decimal(16, 2) // total_ask_side_prem from UW
  bidPrem      Decimal? @map("bid_prem")       @db.Decimal(16, 2) // total_bid_side_prem from UW
  allOpening   Boolean? @map("all_opening")    // every constituent trade is opening (UW.all_opening_trades)
  issueType    String?  @map("issue_type")     @db.VarChar(32)    // "Common Stock" | "ETF" | "ADR" | "Index" | …
  hasFloor     Boolean? @map("has_floor")      // UW.has_floor — distinct from has_sweep
  hasSingleLeg Boolean? @map("has_single_leg") // UW.has_singleleg — true single-leg vs. multi-leg

  @@index([capturedAt(sort: Desc)])
  @@index([ticker, capturedAt(sort: Desc)])
  @@map("flow_alerts")
}

// Per-ticker GEX snapshot. Polling cadence: 60s per watched ticker during
// market hours (ARCHITECTURE §2.1). Per-strike rows stored as JSON to keep
// row count manageable (~5 tickers × 1 row/min × 6.5h = ~2K rows/day).
// Retention: 30 days.
model GexSnapshot {
  id          BigInt   @id @default(autoincrement())
  capturedAt  DateTime @map("captured_at")
  ticker      String   @db.VarChar(10)
  asOf        DateTime @map("as_of") // UW's stated timestamp
  spot        Decimal  @db.Decimal(12, 4)
  netGexOI    Decimal  @map("net_gex_oi") @db.Decimal(20, 2)
  netGexDV    Decimal  @map("net_gex_dv") @db.Decimal(20, 2)
  gammaRegime String   @map("gamma_regime") @db.VarChar(10) // POSITIVE | NEGATIVE
  callWall    Decimal  @map("call_wall") @db.Decimal(12, 4)
  putWall     Decimal  @map("put_wall") @db.Decimal(12, 4)
  gammaFlip   Decimal  @map("gamma_flip") @db.Decimal(12, 4)
  maxPain     Decimal  @map("max_pain") @db.Decimal(12, 4)
  strikes     Json // GEXLevel[] from PRD §18

  @@index([ticker, capturedAt(sort: Desc)])
  @@map("gex_snapshots")
}

// GEX heatmap snapshots — per-(strike × expiration) net gamma.
// Sibling of GexSnapshot: same poll cadence (60s during market hours, fired
// from pollGex), but stores the cross-section UW returns when /spot-exposures/
// strike is called with ?expiry=YYYY-MM-DD for each of the 5 nearest
// expirations. Powers the GEX → Heatmap tab.
// JSON `cells` shape:
//   { expirations: [{date: "YYYY-MM-DD", dte: 0}],
//     strikes: [{ strike: 590, byExp: { "YYYY-MM-DD": {netOI, netDV}, ... } }] }
// Row count: 5 tickers × 1 row/min × 6.5h = ~2K rows/day, 30-day retention.
model GexHeatmapSnapshot {
  id         BigInt   @id @default(autoincrement())
  capturedAt DateTime @map("captured_at")
  ticker     String   @db.VarChar(10)
  asOf       DateTime @map("as_of")
  spot       Decimal  @db.Decimal(12, 4)
  cells      Json

  @@index([ticker, capturedAt(sort: Desc)])
  @@map("gex_heatmap_snapshots")
}

// Per-ticker, per-day Options Sentiment series feeding the /flow-sentiment
// module (per-strike call/put buy-vs-sell bars + intraday replay slider).
// One row per (ticker, tradingDate). Each worker poll of UW
// /api/stock/{ticker}/flow-per-strike (whole-day cumulative full chain) appends
// one snapshot to `minutes`; the replay slider scrubs those snapshots, so its
// time resolution equals the poll cadence (hot tickers 5m, tail hourly — see
// worker/src/index.ts). Retention: 30 days (flow-sentiment-retention sweep).
//
// `minutes` JSON shape — SentimentMinute[] (see lib/types/index.ts):
//   { t: "13:35", callVol, putVol, cpRatio, sentiment: "BEARISH",
//     strikes: [{ k: 700, cA, cB, pA, pB, cP, pP }] }
// where cA/cB = call volume bought-at-ask / sold-at-bid (Buy / Sell), pA/pB the
// put equivalents, and cP/pP the net call / put premium for the strike.
model FlowSentimentDay {
  id          BigInt   @id @default(autoincrement())
  ticker      String   @db.VarChar(10)
  tradingDate DateTime @map("trading_date") @db.Date
  capturedAt  DateTime @map("captured_at")
  spot        Decimal  @db.Decimal(12, 4) // latest reference price (GEX spot or vol-weighted strike)
  minutes     Json

  @@unique([ticker, tradingDate])
  @@index([ticker, tradingDate(sort: Desc)])
  @@map("flow_sentiment_days")
}

// Trade Alerts module — one row per POSITION reconstructed from the Discord
// "Trade Alert Bot" embeds (alphapodtrading server). The worker job
// pollTradeAlerts ingests new alerts every 5 min (market hours), parses the
// embeds into events (open/add/trim/close), stitches them into positions, and
// prices the still-open slice via UW per-contract pricing. Full history is
// retained (no pruning). See worker/src/jobs/trade-alerts.ts.
//
// `events` JSON shape — TradeAlertEvent[] (lib/types/index.ts):
//   { action: "open"|"add"|"trim"|"close", price, fracClosed?, pct?, at, messageId, expired? }
// realizedPct = Σ fracClosed_i × pct_i (banked trims/closes);
// livePct = (lastMark − entryPrice)/entryPrice on the open slice;
// bookDelta = sizeWeight × (realized + remainingFrac × livePct)  [L .10 M .05 S .01 Lotto .005].
model TradeAlert {
  id            BigInt    @id @default(autoincrement())
  openMessageId String    @unique @map("open_message_id") // BUY TO OPEN msg id
  assetType     String    @map("asset_type") @db.VarChar(8) // option | equity
  ticker        String    @db.VarChar(10)
  side          String    @db.VarChar(4) // CALL | PUT | LONG
  strike        Decimal?  @db.Decimal(12, 4)
  expiry        DateTime? @db.Date
  expiryLabel   String?   @map("expiry_label")
  occ           String? // OCC option symbol (options only)
  moderator     String    @db.VarChar(32) // "Alerted by"
  sizeLabel     String    @map("size_label") @db.VarChar(8) // Small|Medium|Large|Lotto
  entryPrice    Decimal   @map("entry_price") @db.Decimal(12, 4)
  entryAt       DateTime  @map("entry_at")
  status        String    @db.VarChar(8) // OPEN | CLOSED
  remainingFrac Decimal   @map("remaining_frac") @db.Decimal(6, 4)
  realizedPct   Decimal   @map("realized_pct") @db.Decimal(12, 4)
  events        Json
  lastMark      Decimal?  @map("last_mark") @db.Decimal(12, 4)
  markedAt      DateTime? @map("marked_at")
  livePct       Decimal?  @map("live_pct") @db.Decimal(12, 4)
  bookDelta     Decimal   @map("book_delta") @db.Decimal(12, 6)
  hidden        Boolean   @default(false) // manually excluded from the track record; not touched by ingest
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([assetType, status, entryAt(sort: Desc)])
  @@map("trade_alerts")
}

// OHLCV price bars for the /charts price-chart feature. Populated by the
// worker's pollCandles job from Polygon /v2/aggs (15-min-delayed tier).
// One row per (ticker, timeframe, bar start). The job keeps the recent tail
// fresh every minute and backfills history on first run per (ticker, tf).
// Volume per timeframe at 10 tickers: ~150 weekly + ~500 daily + ~3K hourly
// ≈ 37K rows total — no retention sweep needed at this scale.
model CandleBar {
  id        BigInt   @id @default(autoincrement())
  ticker    String   @db.VarChar(10)
  timeframe String   @db.VarChar(4) // "1W" | "1D" | "1H"
  barTime   DateTime @map("bar_time") // bar-start, UTC
  open      Decimal  @db.Decimal(12, 4)
  high      Decimal  @db.Decimal(12, 4)
  low       Decimal  @db.Decimal(12, 4)
  close     Decimal  @db.Decimal(12, 4)
  volume    BigInt

  @@unique([ticker, timeframe, barTime])
  @@map("candle_bars")
}

// Dark pool prints — populated by both:
//   (a) live UW polling: GET /api/darkpool/recent every 30s during mkt
//   (b) historical Polygon-sourced S3 backfill (out-of-band; see PRD §3.5)
// Retention rule (v1.2.1):
//   - rank ≤ 100 (top 100 per ticker): retained in PERPETUITY
//   - rank > 100 / null:               30-day rolling window
// Enforced by dp-retention-sweep cron at 03:00 ET.
model DarkPoolPrint {
  id         BigInt   @id @default(autoincrement())
  uwId       String?  @unique @map("uw_id") // UW's print id when present
  executedAt DateTime @map("executed_at")
  ticker     String   @db.VarChar(10)
  price      Decimal  @db.Decimal(12, 4)
  size       Int
  premium    Decimal  @db.Decimal(16, 2)
  volume     BigInt?
  exchangeId Int?     @map("exchange_id") // 4 = dark pool (PRD §10)
  trfId      Int?     @map("trf_id")
  isEtf      Boolean  @default(false) @map("is_etf")
  isExtended Boolean  @default(false) @map("is_extended")
  isIntraday Boolean  @default(true) @map("is_intraday") // 09:30-16:00 ET (PRD §10 Q15)
  rank       Int? // computed against top-100 corpus or pass-through
  percentile Decimal? @db.Decimal(5, 2) // 0–100

  @@index([ticker, executedAt(sort: Desc)])
  @@index([rank])
  @@index([isIntraday, executedAt(sort: Desc)])
  @@map("dark_pool_prints")
}

// 5-min Market Tide buckets from UW /api/market/market-tide?interval_5m=1.
// Polling cadence: 5m during market hours.
// Retention: 30 days.
model MarketTideBar {
  id             BigInt   @id @default(autoincrement())
  bucketStart    DateTime @map("bucket_start") // 5-min bucket start (UTC)
  spyPrice       Decimal  @map("spy_price") @db.Decimal(12, 4)
  netCallPremium Decimal  @map("net_call_premium") @db.Decimal(20, 2)
  netPutPremium  Decimal  @map("net_put_premium") @db.Decimal(20, 2)
  volume         BigInt

  @@unique([bucketStart])
  @@index([bucketStart(sort: Desc)])
  @@map("market_tide_bars")
}

// Top Net Impact daily snapshots — top 10 tickers by |Net Impact| per day,
// computed every 5 min during market hours from intraday flow. Formula:
//   Net Impact = (call_ask_premium − call_bid_premium)
//              + (put_bid_premium  − put_ask_premium)
// See PRD §11. Latest row per (snapshotDate, ticker) replaces prior intraday.
model NetImpactDaily {
  id           BigInt   @id @default(autoincrement())
  snapshotDate DateTime @map("snapshot_date") @db.Date
  ticker       String   @db.VarChar(10)
  netPremium   Decimal  @map("net_premium") @db.Decimal(16, 2)
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([snapshotDate, ticker])
  @@index([snapshotDate, netPremium(sort: Desc)])
  @@map("net_impact_daily")
}

// ═══════════════════════════════════════════════════════════════
// 2. Reference / config
// ═══════════════════════════════════════════════════════════════

// Per-ticker reference. Populated daily by refresh-ticker-metadata cron at
// 05:30 ET — pulls from UW ticker info, falls back to lib/sector-overrides.ts
// for ETFs UW returns no sector for (SPY → Index, GLD → Commodities, etc.).
// `sector` matches the `Sector` union in lib/types/index.ts (15 values:
// 11 GICS + 4 ETF asset classes — PRD §18).
model TickerMetadata {
  ticker    String   @id @db.VarChar(10)
  sector    String   @db.VarChar(32)
  name      String?
  isEtf     Boolean  @default(false) @map("is_etf")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("ticker_metadata")
}

// Daily Watches criteria config (PRD §6). Single-row table — id always 1.
model WatchesCriteria {
  id             Int      @id @default(1)
  minPremium     Int      @default(700000) @map("min_premium")
  confFilter     String   @default("HIGH_MED") @map("conf_filter") // HIGH | HIGH_MED | ALL
  execTypes      String[] @default(["SWEEP", "FLOOR", "BLOCK", "SINGLE"]) @map("exec_types")
  maxAlerts      Int      @default(10) @map("max_alerts")
  excludeSectors String[] @default([]) @map("exclude_sectors")
  requireDp      Boolean  @default(false) @map("require_dp")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("watches_criteria")
}

// ═══════════════════════════════════════════════════════════════
// 3. Computed daily artifacts
// ═══════════════════════════════════════════════════════════════

// Materialized hit list (PRD §6). Worker job hit-list-compute runs at
// 07:30 ET daily; POST /api/admin/criteria triggers same-day rebuild.
// Up to 20 rows per (date, rank). Queryable as: WHERE date = today().
model HitListDaily {
  id                 BigInt   @id @default(autoincrement())
  date               DateTime @db.Date
  rank               Int // 1..20
  ticker             String   @db.VarChar(10)
  price              Decimal  @db.Decimal(12, 4)
  direction          String   @db.VarChar(4) // UP | DOWN
  confidence         String   @db.VarChar(4) // HIGH | MED | LOW
  premium            Decimal  @db.Decimal(16, 2)
  contract           String
  dpConf             Boolean  @map("dp_conf")
  dpRank             Int?     @map("dp_rank")
  dpAge              String?  @map("dp_age") // "today" | "yesterday"
  dpPrem             Decimal? @map("dp_prem") @db.Decimal(16, 2)
  thesis             String   @db.Text
  sector             String   @db.VarChar(32)
  actionabilityScore Decimal  @map("actionability_score") @db.Decimal(8, 4)
  contracts          Json // HitListContract[]
  peers              Json // HitListPeer[]
  theme              Json // HitListTheme
  // Confluence engine (v2): fired signal categories + score breakdown —
  // { flow?, sentiment?, darkpool?, persistence?, agree?, total }
  signals            Json?
  // Weekly-ATR trade targets: { atrW, up05, up1, up2, dn05, dn1, dn2 }
  atrTargets         Json?    @map("atr_targets")
  // Suggested-contract pricing: OCC symbol + price when the list was computed
  // ("Price at Entry", static) + latest 15-min mark.
  contractOcc        String?   @map("contract_occ") @db.VarChar(24)
  contractEntryPrice Decimal?  @map("contract_entry_price") @db.Decimal(12, 4)
  contractLastPrice  Decimal?  @map("contract_last_price") @db.Decimal(12, 4)
  contractMarkedAt   DateTime? @map("contract_marked_at")

  @@unique([date, rank])
  @@index([date(sort: Desc)])
  @@map("hit_list_daily")
}

// Earnings Analyst — one row per upcoming/recent report in the coverage
// universe (tracked tickers + S&P 500 + NDX 100 + Dow 30). Upserted by the
// worker's calendar sweep; expected move refreshes intraday.
model EarningsEvent {
  id              BigInt    @id @default(autoincrement())
  ticker          String    @db.VarChar(10)
  reportDate      DateTime  @map("report_date") @db.Date
  reportTime      String    @map("report_time") @db.VarChar(12) // premarket | postmarket | unknown
  fullName        String?   @map("full_name")
  sector          String?   @db.VarChar(40)
  marketcap       Decimal?  @db.Decimal(20, 0)
  isSp500         Boolean   @default(false) @map("is_sp500")
  epsEstimate     Decimal?  @map("eps_estimate") @db.Decimal(12, 4)
  actualEps       Decimal?  @map("actual_eps") @db.Decimal(12, 4)
  expectedMove    Decimal?  @map("expected_move") @db.Decimal(12, 4)
  expectedMovePct Decimal?  @map("expected_move_pct") @db.Decimal(10, 6)
  preEarningsClose Decimal? @map("pre_earnings_close") @db.Decimal(12, 4)
  fiscalQuarter   String?   @map("fiscal_quarter") @db.VarChar(12)
  // Rollups computed from earnings_history at backfill time
  avgMovePct      Decimal?  @map("avg_move_pct") @db.Decimal(10, 6) // avg |1d move|, last 12 qtrs
  beatCount       Int?      @map("beat_count")
  quarterCount    Int?      @map("quarter_count")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@unique([ticker, reportDate])
  @@index([reportDate])
  @@map("earnings_events")
}

// Per-quarter history from UW /earnings/{ticker} — estimates vs actuals,
// what the options market priced, and what the stock actually did.
model EarningsHistory {
  id              BigInt   @id @default(autoincrement())
  ticker          String   @db.VarChar(10)
  reportDate      DateTime @map("report_date") @db.Date
  reportTime      String?  @map("report_time") @db.VarChar(12)
  fiscalQuarter   String?  @map("fiscal_quarter") @db.VarChar(12)
  epsEstimate     Decimal? @map("eps_estimate") @db.Decimal(12, 4)
  actualEps       Decimal? @map("actual_eps") @db.Decimal(12, 4)
  expectedMovePct Decimal? @map("expected_move_pct") @db.Decimal(10, 6)
  move1dPct       Decimal? @map("move_1d_pct") @db.Decimal(10, 6)
  move1wPct       Decimal? @map("move_1w_pct") @db.Decimal(10, 6)
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([ticker, reportDate])
  @@index([ticker])
  @@map("earnings_history")
}

// AI summaries (Anthropic Haiku batch). V1 scope: per-ticker GEX explanations
// only, written by ai-summarizer at 07:00 ET. Sentiment summary path archived
// in v1.2.3 (PRD §3.4 / §7).
//
// kind format (locked v1.2.2):
//   "gex-{TICKER}-{YYYY-MM-DD}"   — V1 active
//   "sentiment-{YYYY-MM-DD}"      — 🗄 archived, do not generate in V1
model AiSummary {
  id          BigInt   @id @default(autoincrement())
  kind        String   @db.VarChar(64)
  generatedAt DateTime @map("generated_at")
  body        String   @db.Text
  tokensUsed  Int      @default(0) @map("tokens_used")

  @@index([kind, generatedAt(sort: Desc)])
  @@map("ai_summaries")
}

// ═══════════════════════════════════════════════════════════════
// 4. Auth (Auth.js v5 + Whop OAuth provider) — added v1.3
// ═══════════════════════════════════════════════════════════════
//
// Standard NextAuth/@auth/prisma-adapter tables (Account, Session,
// VerificationToken) plus a custom User with Whop membership tracking.
// See ARCHITECTURE §6 Phase F for the auth setup walkthrough.

model User {
  id                  String    @id @default(cuid())
  whopMembershipId    String    @unique @map("whop_membership_id")
  email               String    @unique
  emailVerified       DateTime? @map("email_verified") // standard NextAuth field
  name                String?
  image               String?
  isActive            Boolean   @default(true) @map("is_active")
  createdAt           DateTime  @default(now()) @map("created_at")
  lastLoginAt         DateTime? @map("last_login_at")
  membershipCheckedAt DateTime? @map("membership_checked_at") // for periodic re-check

  accounts Account[]
  sessions Session[]

  @@index([email])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ═══════════════════════════════════════════════════════════════
